```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
target/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Environment
.env
.env.local
*.env.*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Coverage
coverage/
htmlcov/
.coverage

# Temporary files
*.tmp
*.temp

# OS specific
.DS_Store
Thumbs.db

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
```